for nested structures:

regex_row = []
answer_row = []
sources_row = []

for col in df.columns:
	regex_row.append(df[col][0][1])
	answer_row.append(df[col][0][2])
	sources_row.append(df[col][0][3])

results_df = pd.DataFrame([regex_row, answer_row, sources_row],
							columns=df.columns,
							index=['answer', 'source', 'reasoning']
)
print(results_df)

"""
converting juyper to py

jupyter nbconvert --to script your_notebook.ipynb --no-prompt

--no-prompt — removes the # In[1]: cell markers
--output — specify a different output filename
--to html      # renders notebook as a webpage
--to pdf       # exports as PDF
--to markdown  # converts to .md file
-- to script   #converts to a plain .py file.

 """